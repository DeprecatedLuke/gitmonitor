{
	"name": "gitmonitor",
	"version": "0.1.0",
	"module": "src/index.ts",
	"type": "module",
	"bin": {
		"gitmonitor": "src/index.ts"
	},
	"scripts": {
		"start": "bun src/index.ts",
		"dev": "bun --hot src/index.ts",
		"check": "biome check src/ && tsc -p tsconfig.json --noEmit",
		"lint": "biome lint src/",
		"fmt": "biome format --write src/",
		"fix": "biome check --fix --unsafe src/"
	},
	"dependencies": {
		"terminal-kit": "^3.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@types/bun": "^1.3.9",
		"@types/node": "^22",
		"@types/terminal-kit": "2.5.7",
		"typescript": "^5.7.0"
	}
}
